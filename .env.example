# =============================================================================
# Resume Refinery — environment variable reference
# Copy this file to .env and edit as needed.  All values shown are the defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Ollama connection
# -----------------------------------------------------------------------------

# Base URL for the Ollama server.  Use the bare host — do NOT add /v1.
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Document generation (agent.py)
# -----------------------------------------------------------------------------

# Model used for cover letter, resume, and interview-guide generation.
# Any model you have pulled in Ollama works; qwen3.5:4b is faster/lighter.
# Default: qwen3.5:9b
RESUME_REFINERY_MODEL=qwen3.5:9b

# Maximum new tokens for non-thinking generation calls (currently unused
# since generation always uses thinking mode — kept for future use).
# When thinking is enabled, num_predict is unlimited (-1) so that internal
# reasoning doesn't starve actual document output.  The context window
# (NUM_CTX) is the effective cap.
# Default: 8192
RESUME_REFINERY_MAX_TOKENS=8192

# -----------------------------------------------------------------------------
# Review / verification (reviewers.py)
# -----------------------------------------------------------------------------

# Model used for the truthfulness, voice-match, and AI-detection reviewers.
# Can be set to a lighter model (e.g. qwen3.5:4b) to save RAM during reviews.
# Default: qwen3.5:9b
RESUME_REFINERY_REVIEW_MODEL=qwen3.5:9b

# Maximum new tokens the review model may produce per non-thinking review call
# (voice-match & AI-detection).  The truthfulness reviewer uses thinking mode
# and sets num_predict=-1 (bounded only by NUM_CTX).
# Default: 4096
RESUME_REFINERY_REVIEW_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Context window (shared by generation and review)
# -----------------------------------------------------------------------------

# KV-cache size (in tokens) requested from Ollama for every chat call.
# This controls how much text fits in a single prompt.
#
# qwen3.5 supports up to 256 K tokens, but Ollama pre-allocates the full KV
# cache on the GPU/CPU at call time, so larger values consume more RAM:
#
#   8 192  → ~1 GB extra   (may truncate long review prompts)
#  16 384  → ~2 GB extra   ← default; handles career profile + one document
#  32 768  → ~4 GB extra   (headroom for very long career profiles)
#
# If you see "WARNING: Ollama reviewer returned empty content" errors, raise
# this value.  If you get OOM / 500 errors from Ollama, lower it.
# Default: 16384
RESUME_REFINERY_NUM_CTX=32768

# -----------------------------------------------------------------------------
# Repair loop pass limits and convergence
# -----------------------------------------------------------------------------

# Maximum number of review+repair passes per run.  Each pass runs all three
# reviewers (truthfulness, voice, AI-detection), checks convergence, and — if
# any reviewer still fails — runs the unified repair agent before the next pass.
# Set to 1 to review once with no repair attempt.
#
# WARNING — with thinking enabled (the default), each pass costs ~7-10 LLM calls
# and can take 10-20 minutes on a local GPU.  Rough wall-clock estimates:
#   1 pass  →  10-20 min   (review only, no repair)
#   2 passes → 20-40 min   (one repair cycle)
#   3 passes → 30-60 min   ← recommended maximum
#   7 passes → 70-140 min  (NOT recommended with thinking enabled)
#
# Default: 3
RESUME_REFINERY_MAX_REPAIR_PASSES=3

# 0-based pass index at which relaxed acceptance thresholds kick in.
# On passes strictly before this index, the stricter AI-detection criteria apply:
#   - Truthfulness: all claims must be supported (always strict, never relaxed)
#   - Voice: "moderate" or better is accepted (same on all passes, per CR-3.1)
#   - AI detection: zero flags on cover letter and resume
# From this pass onward, AI-detection thresholds relax to allow convergence:
#   - AI detection: total flags on cover letter + resume <= RESUME_REFINERY_AI_FLAG_TOLERANCE
# Default: 1  (relaxed thresholds start on the second pass)
RESUME_REFINERY_RELAXED_PASS_START=1

# Maximum number of AI-detection flags (cover letter + resume combined) allowed
# on relaxed passes (pass >= RESUME_REFINERY_RELAXED_PASS_START).
# Truthfulness is unaffected by this setting.
# Default: 2
RESUME_REFINERY_AI_FLAG_TOLERANCE=2

# -----------------------------------------------------------------------------
# Parallelism
# -----------------------------------------------------------------------------

# Maximum number of concurrent threads for independent LLM calls (reviews,
# evidence matching, repair planning).  Set to 1 for fully sequential execution
# (default).  Set to 3 for full parallelism — useful with cloud-hosted models
# where network latency dominates.  Values above 3 have no additional effect
# since the maximum concurrent operations per phase is 3.
# Default: 1
RESUME_REFINERY_MAX_WORKERS=1

# Maximum number of surgical edits that may fail to match their target text
# in a single repair call before an EditApplicationError is raised.
# Increase if the LLM is producing many edits with minor quoting mismatches.
# Default: 3
RESUME_REFINERY_EDIT_FAIL_THRESHOLD=3

# -----------------------------------------------------------------------------
# Session storage
# -----------------------------------------------------------------------------

# Directory where sessions are persisted.  Each session is a subdirectory
# containing inputs, versioned Markdown sources, DOCX exports, and review JSON.
# Default: ~/.resume_refinery/sessions
# RESUME_REFINERY_SESSIONS_DIR=/path/to/custom/sessions/dir
